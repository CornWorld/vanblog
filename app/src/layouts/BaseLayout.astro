---
import type { SiteConfig, Post } from '@vanblog/sdk';
import PbInit from '../components/PbInit.astro';

interface Props {
  title: string;
  description?: string;
  site?: Partial<SiteConfig>;
  post?: Post;
  path?: string; // e.g. "/posts/xxx"
}

const { title, description, site: siteProp, post, path } = Astro.props;

// Fall back to site config from middleware (lazy-loaded from pb)
const site = siteProp || await Astro.locals.getSite();

const siteName = site?.siteName || 'Vanblog';
const siteDesc = description || site?.siteDesc || '';
const baseUrl = site?.baseUrl || '';

// Canonical URL
const canonicalURL = baseUrl && path ? `${baseUrl.replace(/\/$/, '')}${path}` : undefined;

// Article excerpt for description (strip markdown + HTML, truncate).
// DOMPurify strips tags but keeps text content; we then strip leftover markdown
// punctuation. Must produce plain text — feeds into <meta content={desc}>.
function excerpt(md: string | undefined, max = 160): string {
  if (!md) return siteDesc;
  // Strip HTML tags (functionally equivalent for meta-text extraction)
  const stripped = md.replace(/<[^>]*>/g, '');
  const text = stripped
    .replace(/^#+\s+/gm, '')
    .replace(/[*_`~\[\]()!#>-]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
  return text.length > max ? text.slice(0, max) + '...' : text;
}

const desc = post ? excerpt(post.content) : siteDesc;

// JSON-LD structured data for articles
const articleSchema = post ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  datePublished: post.created,
  dateModified: post.updated,
  author: site?.author ? { '@type': 'Person', name: site.author } : undefined,
  publisher: {
    '@type': 'Organization',
    name: siteName,
  },
  description: desc,
  mainEntityOfPage: canonicalURL ? { '@type': 'WebPage', '@id': canonicalURL } : undefined,
} : undefined;

// JSON-LD for website
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  description: siteDesc,
  url: baseUrl || undefined,
};
---
---
import '../styles/global.css';
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Prevent FOUC: set dark class before paint -->
    <script is:inline>
      (() => {
        const t = localStorage.getItem('vanblog-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Core SEO -->
    <title>{title} - {siteName}</title>
    <meta name="description" content={desc} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- OpenGraph (Facebook / WeChat / others) -->
    <meta property="og:title" content={post?.title || title} />
    <meta property="og:description" content={desc} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={post ? 'article' : 'website'} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    {post && <meta property="article:published_time" content={post.created} />}
    {post && <meta property="article:modified_time" content={post.updated} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={post?.title || title} />
    <meta name="twitter:description" content={desc} />

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href="/api/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title={`${siteName} Atom`} href="/api/atom.xml" />

    <!-- Structured Data (JSON-LD) -->
    {post ? (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <PbInit />
    <header class="sticky top-0 z-10 border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur-sm">
      <div class="container-page flex items-center justify-between h-14 gap-4">
        <a href="/" class="font-bold text-lg text-[var(--color-text)] no-underline hover:opacity-80">
          {siteName}
        </a>
        <nav class="flex items-center gap-1 sm:gap-2 text-sm">
          <a href="/" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">首页</a>
          <a href="/archive" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">归档</a>
          <a href="/timeline" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">时间轴</a>
          <a href="/tags" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors hidden sm:inline">标签</a>
          <a href="/categories" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors hidden sm:inline">分类</a>
          <a href="/search" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">搜索</a>
          <a href="/admin" class="px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">管理</a>
          <button id="theme-toggle" class="ml-1 px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-lg" aria-label="切换主题" title="切换深色/浅色主题">
            <span class="dark:hidden">🌙</span>
            <span class="hidden dark:inline">☀️</span>
          </button>
        </nav>
      </div>
    </header>
    <main class="flex-1 container-page py-8">
      <slot />
    </main>
    <footer class="border-t border-[var(--color-border)] py-8 text-sm text-[var(--color-text-muted)]">
      <div class="container-page flex flex-col sm:flex-row justify-between gap-4">
        <p>&copy; {new Date().getFullYear()} {siteName}. Powered by <a href="https://github.com/cornworld/vanblog" class="underline">Vanblog</a>.</p>
        <p class="flex gap-4">
          <a href="/api/feed.xml" class="hover:text-[var(--color-text)]">RSS</a>
          <a href="/api/atom.xml" class="hover:text-[var(--color-text)]">Atom</a>
          <a href="/api/sitemap.xml" class="hover:text-[var(--color-text)]">Sitemap</a>
        </p>
      </div>
    </footer>

    <!-- Theme toggle logic -->
    <script>
      const btn = document.getElementById('theme-toggle');
      const html = document.documentElement;
      btn?.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        localStorage.setItem('vanblog-theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
