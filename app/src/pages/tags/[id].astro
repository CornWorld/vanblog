---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ErrorState from '../../components/ErrorState.astro';
import type { Tag, Post } from '@vanblog/sdk';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

let tag: Tag;
let posts: Post[] = [];
let error = false;

const pb = Astro.locals.pb;
try {
  tag = await pb.collection('tags').getOne<Tag>(id);
} catch {
  return Astro.redirect('/404');
}

try {
  const result = await pb.collection('posts').getList<Post>(1, 100, {
    filter: `tags ?= "${tag.name}" && status = "published" && deleted = false`,
    sort: '-created',
  });
  posts = result.items;
} catch (e) {
  console.error('[tag] Failed to load posts:', e);
  error = true;
}
---
<BaseLayout title={`#${tag.name}`} path={`/tags/${id}`}>
  <a href="/tags" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] mb-4 inline-block">
    ← 所有标签
  </a>
  <h1 class="mb-2">#{tag.name}</h1>
  {tag.description && (
    <p class="text-[var(--color-text-muted)] mb-6">{tag.description}</p>
  )}

  {error && <ErrorState />}

  {!error && posts.length === 0 && (
    <p class="py-12 text-center text-[var(--color-text-muted)]">该标签下暂无文章。</p>
  )}

  {!error && posts.length > 0 && (
    <ul class="space-y-2 mt-6">
      {posts.map(p => (
        <li class="flex items-baseline gap-3">
          <time class="text-sm text-[var(--color-text-muted)] whitespace-nowrap tabular-nums"
                datetime={p.created}>
            {new Date(p.created).toLocaleDateString('zh-CN')}
          </time>
          <a href={`/posts/${p.id}`} class="hover:text-[var(--color-accent)]">{p.title}</a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
