---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Post } from '@vanblog/sdk';
import { Marked } from 'marked';
import { markedHighlight } from 'marked-highlight';
import hljs from 'highlight.js';
import 'highlight.js/styles/github.css';
import DOMPurify from 'isomorphic-dompurify';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

let post: Post;
try {
  post = await Astro.locals.pb.collection('posts').getOne<Post>(id);
} catch {
  return Astro.redirect('/404');
}

if (post.status === 'draft' || post.deleted) {
  return Astro.redirect('/404');
}

// marked with syntax highlighting
const marked = new Marked(
  markedHighlight({
    langPrefix: 'hljs language-',
    highlight(code, lang) {
      const language = hljs.getLanguage(lang) ? lang : 'plaintext';
      return hljs.highlight(code, { language }).value;
    },
  })
);

// marked with syntax highlighting (sync), then sanitize to prevent XSS
const rawHtml = marked.parse(post.content || '', { async: false }) as string;
const htmlContent = DOMPurify.sanitize(rawHtml, {
  // Allow syntax highlighting classes and common markdown attributes
  ALLOWED_ATTR: ['class', 'href', 'title', 'src', 'alt', 'id', 'name', 'target', 'rel', 'data-language', 'data-id'],
  // ALLOWED_TAGS omitted — isomorphic-dompurify uses built-in defaults (strips <script>, <iframe>, etc.)
});
const created = new Date(post.created).toLocaleDateString('zh-CN');
---
<BaseLayout title={post.title} post={post} path={`/posts/${id}`}>
  <article>
    <h1>{post.title}</h1>
    <p><small>发表于 {created}</small></p>
    <div set:html={htmlContent} />
  </article>
  <hr />
  <p><a href="/">← 返回首页</a></p>
</BaseLayout>
