---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ErrorState from '../../components/ErrorState.astro';
import type { Category, Post } from '@vanblog/sdk';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

let cat: Category;
let posts: Post[] = [];
let error = false;

const pb = Astro.locals.pb;
try {
  cat = await pb.collection('categories').getOne<Category>(id);
} catch {
  return Astro.redirect('/404');
}

try {
  const result = await pb.collection('posts').getList<Post>(1, 100, {
    filter: `category = "${cat.name}" && status = "published" && deleted = false`,
    sort: '-created',
  });
  posts = result.items;
} catch (e) {
  console.error('[category] Failed to load posts:', e);
  error = true;
}
---
<BaseLayout title={cat.name} path={`/categories/${id}`}>
  <a href="/categories" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] mb-4 inline-block">
    ← 所有分类
  </a>
  <h1 class="mb-2">
    {cat.name}
    <span class="text-sm font-normal text-[var(--color-text-muted)] ml-2">[{cat.type}]</span>
  </h1>

  {error && <ErrorState />}

  {!error && posts.length === 0 && (
    <p class="py-12 text-center text-[var(--color-text-muted)]">该分类下暂无文章。</p>
  )}

  {!error && posts.length > 0 && (
    <ul class="space-y-2 mt-6">
      {posts.map(p => (
        <li class="flex items-baseline gap-3">
          <time class="text-sm text-[var(--color-text-muted)] whitespace-nowrap tabular-nums"
                datetime={p.created}>
            {new Date(p.created).toLocaleDateString('zh-CN')}
          </time>
          <a href={`/posts/${p.id}`} class="hover:text-[var(--color-accent)]">{p.title}</a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
