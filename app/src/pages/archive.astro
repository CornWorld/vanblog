---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ErrorState from '../components/ErrorState.astro';
import type { Post } from '@vanblog/sdk';

let posts: Post[] = [];
let error = false;

try {
  const pb = Astro.locals.pb;
  posts = await pb.collection('posts').getFullList<Post>({
    filter: 'status = "published" && deleted = false',
    sort: '-created',
  });
} catch (e) {
  console.error('[archive] Failed to load posts:', e);
  error = true;
}

// Group by year
const byYear: Record<number, Post[]> = {};
for (const post of posts) {
  const year = new Date(post.created).getFullYear();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(post);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---
<BaseLayout title="归档" path="/archive">
  <h1 class="mb-8">归档</h1>
  {
    error ? (
      <ErrorState />
    ) : years.length === 0 ? (
      <p class="py-12 text-center text-[var(--color-text-muted)]">暂无文章。</p>
    ) : (
      <div class="space-y-8">
        {years.map(year => (
          <section>
            <h2 class="text-2xl mb-4 pb-2 border-b border-[var(--color-border)]">{year}</h2>
            <ul class="space-y-2">
              {byYear[year].map(post => (
                <li class="flex items-baseline gap-3">
                  <time class="text-sm text-[var(--color-text-muted)] whitespace-nowrap tabular-nums"
                        datetime={post.created}>
                    {new Date(post.created).toLocaleDateString('zh-CN')}
                  </time>
                  <a href={`/posts/${post.id}`} class="hover:text-[var(--color-accent)]">{post.title}</a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )
  }
</BaseLayout>
