---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - 页面不存在">
  <div class="py-16 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-text-muted)] mb-4">404</h1>
    <p class="text-lg text-[var(--color-text-muted)] mb-8">页面不存在。</p>
    <a href="/" class="inline-flex items-center px-4 py-2 rounded-lg font-medium text-sm bg-[var(--color-accent)] text-white hover:opacity-90 transition-opacity">返回首页</a>
  </div>
</BaseLayout>
