---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ErrorState from '../components/ErrorState.astro';
import type { TimelineEntry } from '@vanblog/sdk';

let entries: TimelineEntry[] = [];
let error = false;

try {
  const pb = Astro.locals.pb;
  entries = await (pb as any).vanblog.timeline.list();
} catch (e) {
  console.error('[timeline] Failed to load:', e);
  error = true;
}
---
<BaseLayout title="时间轴" path="/timeline">
  <h1 class="mb-8">时间轴</h1>

  {error && <ErrorState />}

  {!error && entries.length === 0 && (
    <p class="py-12 text-center text-[var(--color-text-muted)]">暂无数据。</p>
  )}

  {!error && entries.length > 0 && (
    <div class="space-y-8">
      {entries.map(year => (
        <section>
          <h2 class="text-2xl mb-1">
            {year.year}
            <small class="text-[var(--color-text-muted)] font-normal ml-2">({year.count})</small>
          </h2>
          <div class="border-l-2 border-[var(--color-border)] dark:border-[var(--color-border-dark)] pl-6 ml-1 space-y-4">
            {year.months.map(m => (
              <div>
                <h3 class="text-sm text-[var(--color-text-muted)] mb-2">
                  {year.year}.{String(m.month).padStart(2, '0')}
                  <span class="ml-1">({m.count})</span>
                </h3>
                <ul class="space-y-1">
                  {m.titles.map(t => (
                    <li>
                      <a href={`/posts/${t.id}`} class="hover:text-[var(--color-accent)]">{t.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</BaseLayout>
