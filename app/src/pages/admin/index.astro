---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../middleware';
import type { Post } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) {
  return Astro.redirect('/_/');
}

let posts: Post[] = [];

try {
  const pb = Astro.locals.pb;
  const result = await pb.collection('posts').getList<Post>(1, 50, {
    sort: '-updated',
  });
  posts = result.items;
} catch (e) {
  console.error('[admin] Failed to load posts:', e);
}
---
<BaseLayout title="管理">
  <h1>文章管理</h1>
  <p><a href="/admin/new">+ 新建文章</a></p>

  {posts.length === 0 ? (
    <p>暂无文章。<a href="/admin/new">创建第一篇</a></p>
  ) : (
    <table style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="text-align: left; border-bottom: 1px solid #ccc;">
          <th>标题</th>
          <th>状态</th>
          <th>更新时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((post) => (
          <tr style="border-bottom: 1px solid #eee;">
            <td>{post.title}</td>
            <td>{post.status}</td>
            <td>{new Date(post.updated).toLocaleString('zh-CN')}</td>
            <td>
              <a href={`/admin/edit/${post.id}`}>编辑</a>
              {' | '}
              <a href={`/posts/${post.id}`} target="_blank">查看</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</BaseLayout>
