---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { requireAdmin } from '../../middleware';

if (!requireAdmin(Astro)) return Astro.redirect('/_/');
Astro.cache.set(false);

let audits: any[] = [];
try {
  audits = await Astro.locals.pb.collection('audits').getList(1, 100, {
    sort: '-created',
    expand: 'actor',
  }).then(r => r.items);
} catch (e) {
  console.error('[admin/audits] load:', e);
}

function expandName(a: any): string {
  const u = a?.expand?.actor;
  return u?.username || u?.email || a?.actor || '-';
}
---
<BaseLayout title="审计日志">
  <h1>审计日志</h1>
  <p><a href="/admin">← 返回</a></p>

  {audits.length === 0 ? (
    <p>暂无审计记录。</p>
  ) : (
    <table class="w-full border-collapse text-xs">
      <thead>
        <tr class="text-left border-b border-[var(--color-border)]">
          <th>时间</th><th>用户</th><th>动作</th><th>目标</th><th>结果</th><th>IP</th><th>详情</th>
        </tr>
      </thead>
      <tbody>
        {audits.map(a => (
          <tr class="border-b border-[var(--color-border)] align-top">
            <td><small>{new Date(a.created).toLocaleString('zh-CN')}</small></td>
            <td>{expandName(a)}</td>
            <td>{a.action}</td>
            <td class="break-all">{a.target}</td>
            <td>{a.result === 'failure' ? (
              <span class="text-red-600">失败</span>
            ) : <span class="text-green-600">成功</span>}</td>
            <td><small>{a.ip || '-'}</small></td>
            <td>
              {a.detail && (
                <details>
                  <summary class="cursor-pointer">查看</summary>
                  <pre class="whitespace-pre-wrap text-[11px] bg-gray-50 p-1">{JSON.stringify(a.detail, null, 2)}</pre>
                </details>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</BaseLayout>
