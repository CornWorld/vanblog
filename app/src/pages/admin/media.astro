---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated, hasPermission } from '../../middleware';
import type { Media } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) {
  return Astro.redirect('/_/');
}

Astro.cache.set(false);

// Mirror Go-side canManageMedia: admin or article:delete holder.
const canDelete = !!hasPermission(Astro, 'article:delete');

let media: Media[] = [];

try {
  const pb = Astro.locals.pb;
  media = await pb.collection('media').getFullList<Media>({ sort: '-created' });
} catch (e) {
  console.error('[admin/media] Failed to load:', e);
}
---
<BaseLayout title="媒体管理">
  <h1>媒体管理</h1>
  <p><a href="/admin">← 返回管理</a></p>

  {media.length === 0 ? (
    <p>暂无媒体文件。</p>
  ) : (
    <div class="flex flex-wrap gap-4">
      {media.map(m => (
        <figure class="m-0 w-40 border border-[var(--color-border)] p-2">
          {m.staticType === 'img' && (
            <img
              src={`/api/files/media/${m.id}/${m.file}`}
              alt={m.file}
              loading="lazy"
              class="w-full h-[120px] object-cover block"
            />
          )}
          <figcaption class="text-xs mt-1 break-all">
            {m.file}
            <br />
            <small class="text-[var(--color-text-muted)]">[{m.storageType}/{m.fileType}]</small>
          </figcaption>
          {canDelete && (
            <button
              type="button"
              class="btn-delete text-red-600 text-xs mt-1"
              data-id={m.id}
              data-name={m.file}
            >删除</button>
          )}
        </figure>
      ))}
    </div>
  )}

  <script define:vars={{}}>
    document.querySelectorAll('button.btn-delete[data-id]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const name = btn.dataset.name;
        const pb = window.__pb;
        if (!id) return;
        if (!confirm(`确认删除媒体文件 ${name}？该操作不可撤销。`)) return;
        if (!pb) return alert('未登录');
        try {
          await pb.vanblog.media.delete(id);
          btn.closest('figure')?.remove();
        } catch (err) {
          alert('删除失败: ' + err.message);
        }
      });
    });
  </script>
</BaseLayout>
