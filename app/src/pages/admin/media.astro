---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../middleware';
import type { Media } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) {
  return Astro.redirect('/_/');
}

Astro.cache.set(false);

let media: Media[] = [];

try {
  const pb = Astro.locals.pb;
  media = await pb.collection('media').getFullList<Media>({ sort: '-created' });
} catch (e) {
  console.error('[admin/media] Failed to load:', e);
}
---
<BaseLayout title="媒体管理">
  <h1>媒体管理</h1>
  <p><a href="/admin">← 返回管理</a></p>

  {media.length === 0 ? (
    <p>暂无媒体文件。</p>
  ) : (
    <div class="flex flex-wrap gap-4">
      {media.map(m => (
        <figure class="m-0 w-40 border border-[var(--color-border)] p-2">
          {m.staticType === 'img' && (
            <img
              src={`/api/files/media/${m.id}/${m.file}`}
              alt={m.file}
              loading="lazy"
              class="w-full h-[120px] object-cover block"
            />
          )}
          <figcaption class="text-xs mt-1 break-all">
            {m.file}
            <br />
            <small class="text-[var(--color-text-muted)]">[{m.storageType}/{m.fileType}]</small>
          </figcaption>
        </figure>
      ))}
    </div>
  )}
</BaseLayout>
