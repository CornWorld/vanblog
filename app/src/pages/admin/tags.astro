---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated, getAuthUser } from '../../middleware';
import type { Tag } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) return Astro.redirect('/_/');
Astro.cache.set(false);
const user = getAuthUser(Astro);

let tags: Tag[] = [];
try {
  tags = await Astro.locals.pb.collection('tags').getFullList<Tag>({ sort: 'name' });
} catch (e) {
  console.error('[admin/tags] load:', e);
}
---
<BaseLayout title="标签管理">
  <h1>标签管理</h1>
  <p><a href="/admin">← 返回</a></p>

  <form id="new-tag" class="flex gap-2 flex-wrap mb-4">
    <input name="name" placeholder="标签名" required class="px-1.5 py-0.5 flex-1 min-w-[160px]" />
    <input name="slug" placeholder="slug（可空）" class="px-1.5 py-0.5 w-40" />
    <input name="description" placeholder="描述（可空）" class="px-1.5 py-0.5 w-60" />
    <button type="submit">+ 新建</button>
  </form>

  <table class="w-full border-collapse">
    <thead>
      <tr class="text-left border-b border-[var(--color-border)]">
        <th>名称</th><th>slug</th><th>描述</th><th>操作</th>
      </tr>
    </thead>
    <tbody>
      {tags.map(t => (
        <tr data-id={t.id} class="border-b border-[var(--color-border)]">
          <td><input class="f-name" value={t.name} class="w-full" /></td>
          <td><input class="f-slug" value={t.slug || ''} class="w-full" /></td>
          <td><input class="f-desc" value={t.description || ''} class="w-full" /></td>
          <td class="flex gap-2">
            <button class="btn-save">保存</button>
            <button class="btn-del" class="text-red-600">删除</button>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  {tags.length === 0 && <p>暂无标签。</p>}

  <script>
    const pb = window.__pb;

    document.getElementById('new-tag')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!pb) return;
      const fd = new FormData(e.target as HTMLFormElement);
      try {
        await pb.collection('tags').create({
          name: fd.get('name'),
          slug: fd.get('slug') || undefined,
          description: fd.get('description') || undefined,
        });
        location.reload();
      } catch (err) { alert('新建失败: ' + (err as Error).message); }
    });

    document.querySelectorAll<HTMLElement>('tr[data-id]').forEach((tr) => {
      const id = tr.dataset.id!;
      if (!pb) return;
      tr.querySelector<HTMLElement>('.btn-save')!.onclick = async () => {
        try {
          await pb.collection('tags').update(id, {
            name: (tr.querySelector('.f-name') as HTMLInputElement).value,
            slug: (tr.querySelector('.f-slug') as HTMLInputElement).value,
            description: (tr.querySelector('.f-desc') as HTMLInputElement).value,
          });
          alert('已保存');
        } catch (err) { alert('保存失败: ' + (err as Error).message); }
      };
      tr.querySelector<HTMLElement>('.btn-del')!.onclick = async () => {
        if (!confirm('确定删除该标签？')) return;
        try {
          await pb.collection('tags').delete(id);
          tr.remove();
        } catch (err) { alert('删除失败: ' + (err as Error).message); }
      };
    });
  </script>
</BaseLayout>
