---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../../middleware';
import type { Revision, Post } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) {
  return Astro.redirect('/_/');
}

Astro.cache.set(false);

const { postId } = Astro.params;
if (!postId) return Astro.redirect('/404');

let post: Post;
let revs: Revision[] = [];

const pb = Astro.locals.pb;
try {
  post = await pb.collection('posts').getOne<Post>(postId);
} catch {
  return Astro.redirect('/404');
}

try {
  revs = await pb.collection('revisions').getFullList<Revision>({
    filter: `target = "${postId}"`,
    sort: '-created',
  });
} catch (e) {
  console.error('[revisions] Failed to load:', e);
}
---
<BaseLayout title={`修订历史 - ${post.title}`}>
  <h1>修订历史</h1>
  <p><a href="/admin">← 返回管理</a> ｜ <a href={`/admin/edit/${postId}`}>编辑</a></p>
  <p><strong>文章：</strong>{post.title}</p>
  <hr />

  {revs.length === 0 ? (
    <p>暂无修订记录。</p>
  ) : (
    <ul class="list-none p-0 flex flex-col gap-3">
      {revs.map(r => (
        <li class="border border-[var(--color-border)] p-3">
          <div class="flex justify-between gap-4 flex-wrap">
            <strong>{r.reason || '(无原因)'}</strong>
            <small class="text-[var(--color-text-muted)]">{new Date(r.created).toLocaleString('zh-CN')}</small>
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">
            by {r.authoredBy || '-'}
          </div>
          {r.snapshot && (
            <details class="mt-2">
              <summary class="cursor-pointer">快照</summary>
              <pre class="whitespace-pre-wrap text-xs bg-gray-50 p-2">{JSON.stringify(r.snapshot, null, 2)}</pre>
            </details>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
