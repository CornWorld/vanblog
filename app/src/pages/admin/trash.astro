---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated, getAuthUser, hasPermission } from '../../middleware';
import type { TrashEntry } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) return Astro.redirect('/_/');
Astro.cache.set(false);

const user = getAuthUser(Astro);
const isAdmin = user?.role === 'admin';
const canEditPost = !!hasPermission(Astro, 'article:create') || !!hasPermission(Astro, 'article:update');

// Gate the whole page; mirrors the backend canManagePosts check.
if (!canEditPost) return Astro.redirect('/admin');

let trash: TrashEntry[] = [];
try {
  // Auth enforced by Go route (canManagePosts). Do NOT query pb.collection
  // directly — that path depends on the posts ListRule, which we plan to
  // tighten; the trash endpoint is the stable contract for admin UI.
  trash = await Astro.locals.pb.vanblog.posts.trash();
} catch (e) {
  console.error('[admin/trash] load:', e);
}
---

<BaseLayout title="回收站">
  <h1>回收站</h1>
  <p><a href="/admin">← 返回</a></p>

  {trash.length === 0 ? (
    <p>回收站为空。</p>
  ) : (
    <table class="w-full border-collapse">
      <thead>
        <tr class="text-left border-b border-[var(--color-border)]">
          <th>标题</th><th>状态</th><th>删除时间</th><th>操作</th>
        </tr>
      </thead>
      <tbody>
        {trash.map(post => (
          <tr data-id={post.id} class="border-b border-[var(--color-border)]">
            <td>{post.title}</td>
            <td>{post.status}</td>
            <td>{new Date(post.updated).toLocaleString('zh-CN')}</td>
            <td class="flex gap-2 flex-wrap">
              <button class="btn-restore">恢复</button>
              {isAdmin && (
                <button class="btn-purge" class="text-red-600">彻底删除</button>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  <script define:vars={{}}>
    document.querySelectorAll('tr[data-id]').forEach((tr) => {
      const id = tr.dataset.id;
      const pb = window.__pb;

      tr.querySelector('.btn-restore').addEventListener('click', async () => {
        if (!id || !confirm('恢复该文章？（deleted=false）')) return;
        if (!pb) return alert('未登录');
        try {
          await pb.vanblog.posts.restore(id);
          location.reload();
        } catch (err) {
          alert('恢复失败: ' + err.message);
        }
      });

      const purgeBtn = tr.querySelector('.btn-purge');
      if (purgeBtn) {
        purgeBtn.addEventListener('click', async () => {
          if (!id) return;
          if (!confirm('彻底删除？该操作不可撤销（pb delete）。')) return;
          if (!pb) return alert('未登录');
          try {
            await pb.collection('posts').delete(id);
            location.reload();
          } catch (err) {
            alert('删除失败: ' + err.message);
          }
        });
      }
    });
  </script>
</BaseLayout>
