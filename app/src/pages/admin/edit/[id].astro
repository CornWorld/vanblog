---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../../middleware';
import ByteMdEditor from '../../../components/ByteMdEditor.astro';
import type { Post } from '@vanblog/sdk';

if (!isAuthenticated(Astro)) {
  return Astro.redirect('/_/');
}

// Admin pages are personalized — opt out of route cache entirely.
Astro.cache.set(false);

const { id } = Astro.params;
const isNew = !id || id === 'new';

let post: Partial<Post> = {};
if (!isNew) {
  try {
    post = await Astro.locals.pb.collection('posts').getOne<Post>(id);
  } catch {
    return Astro.redirect('/404');
  }
}

// Pass site.mediaConfig to the editor so its client-side normalization
// (BMP/TIFF → WebP/AVIF) matches what the user configured. Without this,
// the editor falls back to the package default (webp/84), which silently
// diverges from a user who set targetFormat=avif via Admin UI.
const site = await Astro.locals.getSite();
const mediaConfig = site?.mediaConfig;
---
<BaseLayout title={isNew ? '新建文章' : '编辑文章'}>
  <h1>{isNew ? '新建文章' : '编辑文章'}</h1>
  <div style="margin-bottom: 1rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: end;">
    <label>标题 <input type="text" id="f-title" value={post.title || ''} required style="width: 300px; padding: 0.3rem;" /></label>
    <label>路径 <input type="text" id="f-path" value={post.pathname || ''} placeholder="/my-post" style="width: 200px; padding: 0.3rem;" /></label>
    <label>状态
      <select id="f-status">
        <option value="draft" selected={post.status !== 'published' && post.status !== 'hidden'}>草稿</option>
        <option value="published" selected={post.status === 'published'}>已发布</option>
        <option value="hidden" selected={post.status === 'hidden'}>隐藏</option>
      </select>
    </label>
  </div>

  <ByteMdEditor initialContent={post.content || ''} mediaConfig={mediaConfig} />

  <div style="margin-top: 0.5rem; display: flex; gap: 1rem;">
    <button id="btn-save" type="button">保存</button>
    <button id="btn-publish" type="button">保存并发布</button>
    <a href="/admin">取消</a>
  </div>

  <script define:vars={{ postId: isNew ? null : id }}>
    const save = async (publish) => {
      const pb = window.__pb;
      if (!pb) return alert('未登录');

      const data = {
        title: document.getElementById('f-title').value,
        pathname: document.getElementById('f-path').value,
        content: document.getElementById('post-content').value,
        status: publish ? 'published' : document.getElementById('f-status').value,
        deleted: false,
      };

      try {
        if (postId) await pb.collection('posts').update(postId, data);
        else await pb.collection('posts').create(data);
        location.href = '/admin';
      } catch (e) { alert('保存失败: ' + e.message); }
    };

    document.getElementById('btn-save').onclick = () => save(false);
    document.getElementById('btn-publish').onclick = () => save(true);
  </script>
</BaseLayout>
