---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ByteMdEditor from '../../../components/ByteMdEditor.astro';
import type { Post } from '@vanblog/sdk';

const { id } = Astro.params;

let post: Post | null = null;
let mode = 'new';

if (id) {
  mode = 'edit';
  try {
    const pb = Astro.locals.pb;
    post = await pb.collection('posts').getOne<Post>(id);
  } catch {
    return Astro.redirect('/404');
  }
}
---
<BaseLayout title={mode === 'edit' ? '编辑文章' : '新建文章'}>
  <h1>{mode === 'edit' ? '编辑文章' : '新建文章'}</h1>

  <form id="post-form">
    <div style="margin-bottom: 1rem;">
      <label>
        标题:
        <input
          type="text"
          id="post-title"
          name="title"
          value={post?.title || ''}
          required
          style="width: 100%; padding: 0.5rem; font-size: 1rem;"
        />
      </label>
    </div>

    <div style="margin-bottom: 1rem;">
      <label>
        路径:
        <input
          type="text"
          id="post-pathname"
          name="pathname"
          value={post?.pathname || ''}
          style="width: 100%; padding: 0.5rem;"
          placeholder="/my-post"
        />
      </label>
    </div>

    <div style="margin-bottom: 1rem; display: flex; gap: 1rem;">
      <label>
        状态:
        <select id="post-status" name="status">
          <option value="draft" selected={post?.status === 'draft' || !post}>草稿</option>
          <option value="published" selected={post?.status === 'published'}>已发布</option>
          <option value="hidden" selected={post?.status === 'hidden'}>隐藏</option>
        </select>
      </label>
    </div>
  </form>

  <ByteMdEditor initialContent={post?.content || ''} postId={post?.id} />

  <div style="margin-top: 1rem; display: flex; gap: 1rem;">
    <button id="save-btn" type="button">保存</button>
    <button id="save-publish-btn" type="button">保存并发布</button>
    <a href="/admin">取消</a>
  </div>

  <script define:vars={{ postId: post?.id || null }}>
    async function save(publish = false) {
      const title = document.getElementById('post-title').value;
      const pathname = document.getElementById('post-pathname').value;
      const status = publish ? 'published' : document.getElementById('post-status').value;
      const content = document.getElementById('post-content').value;

      const pb = window.__pb || null;
      if (!pb) {
        alert('未登录');
        return;
      }

      const data = { title, content, status, pathname, deleted: false };

      try {
        if (postId) {
          await pb.collection('posts').update(postId, data);
        } else {
          await pb.collection('posts').create(data);
        }
        alert('保存成功');
        window.location.href = '/admin';
      } catch (e) {
        alert('保存失败: ' + e.message);
      }
    }

    document.getElementById('save-btn').addEventListener('click', () => save(false));
    document.getElementById('save-publish-btn').addEventListener('click', () => save(true));
  </script>
</BaseLayout>
