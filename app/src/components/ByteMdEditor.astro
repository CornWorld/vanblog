---
import 'bytemd/dist/index.css'
import 'highlight.js/styles/github.css'

interface Props { initialContent?: string; postId?: string }
const { initialContent = '', postId } = Astro.props
---
<div id="bytemd-editor" data-initial={initialContent} style="height: calc(100vh - 200px);"></div>
<input type="hidden" id="post-content" value={initialContent} />

<script>
  import { Editor } from 'bytemd';
  import gfm from '@bytemd/plugin-gfm';
  import highlight from '@bytemd/plugin-highlight-ssr';
  import math from '@bytemd/plugin-math-ssr';
  import frontmatter from '@bytemd/plugin-frontmatter';
  import mediumZoom from '@bytemd/plugin-medium-zoom';
  import mermaid from '@bytemd/plugin-mermaid';
  import { visit } from 'unist-util-visit';
  import remarkDirective from 'remark-directive';
  import 'katex/dist/katex.css';

  // rehype: 标题加 data-id + 链接加 target=_blank (一次遍历)
  const rehypeEnhance = () => (tree) => visit(tree, (n) => {
    if (n.type !== 'element') return;
    if (/^h[1-6]$/.test(n.tagName) && n.children?.[0]?.value)
      n.properties['data-id'] = n.children[0].value;
    if (n.tagName === 'a') { n.properties.target = '_blank'; n.properties.rel = 'noopener noreferrer'; }
  });

  // rehype: 代码块加复制按钮
  const rehypeCodeBlock = () => (tree) => visit(tree, (n) => {
    if (n.type !== 'element' || n.tagName !== 'pre') return;
    const code = n.children?.find((c) => c.tagName === 'code');
    if (!code) return;
    const lang = (code.properties?.className || []).find((c) => c?.startsWith?.('language-'))?.replace('language-', '') || '';
    if (lang === 'mermaid') return;
    n.properties.class = 'code-block-wrapper';
    n.children = [{
      type: 'element', tagName: 'div',
      properties: { class: 'code-header', style: 'display:flex;justify-content:flex-end;padding:2px 8px;font-size:12px;color:#6f7177' },
      children: [
        { type: 'element', tagName: 'span', properties: {}, children: [{ type: 'text', value: lang }] },
        { type: 'element', tagName: 'span', properties: { class: 'code-copy-btn', style: 'cursor:pointer;margin-left:8px' }, children: [{ type: 'text', value: '复制' }] },
      ],
    }, ...n.children];
  });

  // remark: :::tip / :::warning 自定义容器
  const remarkContainer = () => (tree) => visit(tree, (n) => {
    if (n.type !== 'containerDirective') return;
    const titles = { note: '注', info: '相关信息', warning: '注意', danger: '警告', tip: '提示' };
    const title = n.attributes?.title || titles[n.name] || n.name;
    n.data = n.data || {};
    n.data.hName = 'div';
    n.data.hProperties = { class: 'custom-container ' + n.name };
    n.children.unshift({
      type: 'paragraph',
      data: { hProperties: { class: 'custom-container-title' } },
      children: [{ type: 'text', value: title }],
    });
  });

  // action: 插入 <!-- more -->
  const moreAction = {
    title: '插入 more',
    icon: '<svg fill="currentColor" viewBox="0 0 1024 1024" width="16" height="16"><circle cx="227" cy="509" r="95"/><circle cx="511" cy="509" r="95"/><circle cx="795" cy="509" r="95"/></svg>',
    handler: { type: 'action', click(ctx) {
      const pos = ctx.appendBlock('<!-- more -->\n');
      ctx.editor.focus();
    }},
  };

  // action: 剪切板图片上传
  function imgAction(getPb) {
    return {
      title: '图片上传',
      icon: '<svg viewBox="0 0 1024 1024" width="16" height="16" fill="currentColor"><path d="M768 128h-50A128 128 0 00597 43H427a128 128 0 00-121 85H256a128 128 0 00-128 128v597a128 128 0 00128 128h512a128 128 0 00128-128V256a128 128 0 00-128-128zM427 128h170a43 43 0 010 85H427a43 43 0 010-85zm384 725a43 43 0 01-43 43H256a43 43 0 01-43-43V256a43 43 0 0143-43h50A128 128 0 00427 299h170a128 128 0 00121-86h50a43 43 0 0143 43v597z"/></svg>',
      handler: { type: 'action', async click(ctx) {
        try {
          const items = await navigator.clipboard.read();
          for (const item of items)
            for (const type of item.types)
              if (type.startsWith('image/')) {
                const blob = await item.getType(type);
                const file = new File([blob], 'clip-' + Date.now() + '.png', { type });
                const pb = getPb(); if (!pb) return;
                const fd = new FormData();
                fd.append('file', file); fd.append('staticType', 'img'); fd.append('storageType', 'local');
                const rec = await pb.collection('media').create(fd);
                const url = pb.files.getRecordUrl(rec, rec.file);
                ctx.appendBlock('![' + file.name + '](' + url + ')');
                ctx.editor.focus();
              }
        } catch { alert('剪切板无图片'); }
      }},
    };
  }

  // action: 自定义容器下拉
  const containerAction = {
    title: '高亮块',
    icon: '<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><rect x="1" y="1" width="14" height="6" rx="1" fill="none" stroke="currentColor"/><rect x="1" y="9" width="14" height="6" rx="1" fill="none" stroke="currentColor"/></svg>',
    handler: { type: 'dropdown', actions: [
      { title: 'tip', handler: { type: 'action', click: (ctx) => { ctx.appendBlock(':::tip\n提示内容\n:::\n'); ctx.editor.focus(); }}},
      { title: 'warning', handler: { type: 'action', click: (ctx) => { ctx.appendBlock(':::warning\n注意内容\n:::\n'); ctx.editor.focus(); }}},
      { title: 'info', handler: { type: 'action', click: (ctx) => { ctx.appendBlock(':::info\n相关信息\n:::\n'); ctx.editor.focus(); }}},
      { title: 'danger', handler: { type: 'action', click: (ctx) => { ctx.appendBlock(':::danger\n警告内容\n:::\n'); ctx.editor.focus(); }}},
    ]},
  };

  // 复制按钮事件绑定
  function bindCopyBtns(markdownBody) {
    markdownBody.querySelectorAll('.code-copy-btn').forEach((btn) => {
      btn.onclick = () => {
        const code = btn.closest('.code-block-wrapper')?.querySelector('code')?.textContent;
        if (!code) return;
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = '✓';
          setTimeout(() => btn.textContent = '复制', 1500);
        });
      };
    });
  }

  // ---- Mount ----
  const mount = document.getElementById('bytemd-editor');
  const hiddenInput = document.getElementById('post-content');

  if (mount) {
    const plugins = [
      gfm(), highlight(), math(), frontmatter(), mediumZoom(), mermaid(),
      // rehype: 标题锚点 + 链接新窗口 (合并为一次遍历)
      { rehype: (p) => p.use(rehypeEnhance) },
      // rehype: 代码块复制按钮
      { rehype: (p) => p.use(rehypeCodeBlock), viewerEffect: ({ markdownBody }) => bindCopyBtns(markdownBody) },
      // remark: 自定义容器
      { remark: (p) => p.use(remarkDirective).use(remarkContainer) },
      // actions
      { actions: [moreAction, imgAction(() => window.__pb), containerAction] },
    ];

    const editor = new Editor({
      target: mount,
      props: { value: mount.dataset.initial || '', plugins, mode: 'split', placeholder: '开始写作...' },
    });

    editor.$on('change', (e) => {
      editor.$set({ value: e.detail.value });
      if (hiddenInput) hiddenInput.value = e.detail.value;
    });

    window.__bytemdEditor = editor;
  }
</script>
