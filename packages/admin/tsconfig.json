{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    // Vite handles emit
    "noEmit": false,
    // React/Vite specific
    "allowJs": true
  },
  "include": ["src", "src/**/*.json", "config"],
  "exclude": ["node_modules", "dist", "build"]
}
