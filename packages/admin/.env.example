# VanBlog Admin Environment Configuration Example
# Copy this file to .env.local and customize the values

# ===================
# API Configuration
# ===================

# API base URL (proxied by Vite dev server)
VITE_API_URL=http://localhost:3050

# Upload API endpoint
VITE_UPLOAD_API_ENDPOINT=/api/v2/media

# ===================
# Network Settings
# ===================

# Request timeout in milliseconds
VITE_REQUEST_TIMEOUT=30000

# ===================
# Development Settings
# ===================

# Enable preview mode (uses mock data)
# VITE_PREVIEW_MODE=false

# Enable verbose logging
# VITE_DEBUG=false
