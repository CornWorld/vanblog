# VanBlog Website Environment Configuration Example
# Copy this file to .env.local and customize the values

# ===================
# API Configuration
# ===================

# Public API URL (accessible from browser)
NEXT_PUBLIC_VANBLOG_SERVER_URL=http://127.0.0.1:3050

# Server-side API URL (for SSR/SSG)
VAN_BLOG_SERVER_URL=http://127.0.0.1:3050

# Waline comment system URL
VAN_BLOG_WALINE_URL=http://127.0.0.1:8360

# ===================
# API Client Settings
# ===================

# Request timeout in milliseconds
VAN_BLOG_API_TIMEOUT=10000

# Maximum number of retry attempts
VAN_BLOG_API_MAX_RETRIES=3

# ===================
# Build & Development
# ===================

# Node environment (automatically set by Next.js)
# NODE_ENV=development

# Enable verbose logging during build
# NEXT_PUBLIC_DEBUG=false
