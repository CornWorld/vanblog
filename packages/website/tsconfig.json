{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    // Next.js specific
    "allowJs": true,
    "noEmit": false,
    // Next.js uses node module resolution
    "module": "esnext",
    "moduleResolution": "node",
    // Relax strict for legacy code
    "strict": false,
    "paths": {
      "react": ["./node_modules/@types/react"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
