{
  "$schema": "./config.schema.json",
  "PORT": 3050,
  "NODE_ENV": "development",
  "API_PREFIX": "api",
  "API_VERSION": "v2",
  "DATABASE_DRIVER": "local",
  "DATABASE_URL": "file:./data/vanblog.db",
  "JWT_SECRET": "your-secret-key-at-least-32-characters-long-please-change-me",
  "JWT_EXPIRES_IN": "7d",
  "JWT_REFRESH_SECRET": "your-refresh-secret-at-least-32-characters-long-please-change-me",
  "JWT_REFRESH_EXPIRES_IN": "30d",
  "CORS_ORIGIN": "http://localhost:3001,http://localhost:3002",
  "CORS_CREDENTIALS": true,
  "UPLOAD_MAX_FILE_SIZE": 52428800,
  "UPLOAD_DESTINATION": "./uploads",
  "STATIC_PATH": "/app/static",
  "LOG_LEVEL": "info",
  "LOG_DIR": "/var/log/vanblog",
  "WALINE_DB": "waline",
  "DEMO_MODE": false,
  "CODE_RUNNER_PATH": "/app/codeRunner",
  "PLUGIN_RUNNER_PATH": "/app/pluginRunner"
}
