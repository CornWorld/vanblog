{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["node", "vitest/globals", "express", "multer"],
    // Disable verbatimModuleSyntax for NestJS DI compatibility
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*", "test/**/*", "plugins/**/*", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
