{
  "name": "@vanblog/server-ng",
  "version": "0.54.0-corn.6",
  "description": "VanBlog Server-NG - A modern, modular, and high-performance API server for VanBlog",
  "author": "VanBlog Team",
  "private": true,
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mereithhh/vanblog.git",
    "directory": "packages/server-ng"
  },
  "bugs": {
    "url": "https://github.com/Mereithhh/vanblog/issues"
  },
  "homepage": "https://vanblog.mereith.com",
  "scripts": {
    "dev": "pnpm config:schema && vite",
    "prebuild": "rimraf dist && pnpm config:schema",
    "build": "vite build",
    "build:plugins": "vite build --config vite.plugin.config.mts",
    "build:all": "pnpm run build && pnpm run build:plugins",
    "build:combine": "node scripts/combine-build.js",
    "build:production": "pnpm run build:all && pnpm run build:combine",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "nest": "nest start",
    "nest:dev": "nest start --watch",
    "nest:debug": "nest start --debug --watch",
    "nest:prod": "node dist/main",
    "lint": "eslint --format=compact -c ./eslint.config.mjs",
    "test:quick": "vitest run --config vitest.config.quick.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "test:e2e:watch": "vitest --config ./vitest.config.e2e.ts",
    "test:all": "pnpm test:quick && pnpm test && pnpm test:e2e",
    "test:ai": "echo '⚠️  AI E2E tests not yet implemented' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "config:schema": "tsx scripts/generate-config-schema.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.10",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.16",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.5",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/throttler": "^6.4.0",
    "@ts-rest/core": "3.53.0-rc.1",
    "@ts-rest/nest": "3.53.0-rc.1",
    "@vanblog/shared": "workspace:*",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "feed": "^4.2.2",
    "helmet": "^8.1.0",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-task-lists": "^2.1.1",
    "multer": "^2.0.2",
    "next": "16.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "picgo": "^1.5.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "^7.7.2",
    "sharp": "^0.33.5",
    "sitemap": "^8.0.0",
    "ua-parser-js": "^2.0.4",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@faker-js/faker": "^9.3.0",
    "@nestjs/cli": "^11.0.6",
    "@nestjs/swagger": "^11.1.2",
    "@nestjs/testing": "^11.0.16",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.14.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-unix": "^8.40.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "ms": "^2.1.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "unplugin-swc": "^1.5.4",
    "vite": "^7.2.4",
    "vite-plugin-node": "^5.0.1",
    "vitest": "^4.0.14"
  }
}
