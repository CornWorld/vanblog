# Application
PORT=3000
NODE_ENV=development
API_PREFIX=api
API_VERSION=v2

# Database
MONGODB_URI=mongodb://localhost:27017/vanblog
# 或者使用分离的配置
# DATABASE_HOST=localhost
# DATABASE_PORT=27017
# DATABASE_NAME=vanblog
# DATABASE_USER=
# DATABASE_PASS=

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true

# File Upload
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_DESTINATION=./uploads

# Static Files
STATIC_PATH=/app/static

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/vanblog

# Waline (Comment System)
WALINE_DB=waline

# Demo Mode
DEMO_MODE=false

# Code Runner
CODE_RUNNER_PATH=/app/codeRunner
PLUGIN_RUNNER_PATH=/app/pluginRunner

