# Application
PORT=3000
NODE_ENV=development
API_PREFIX=api
API_VERSION=v2

# Database Configuration
DATABASE_DRIVER=local # local | turso | d1
DATABASE_URL=file:./data/vanblog.db

# For Turso (Remote SQLite)
# DATABASE_DRIVER=turso
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# For Cloudflare D1
# DATABASE_DRIVER=d1
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_DATABASE_ID=your-database-id
# CLOUDFLARE_D1_TOKEN=your-d1-token

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true

# File Upload
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_DESTINATION=./uploads

# Static Files
STATIC_PATH=/app/static

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/vanblog

# Waline (Comment System)
WALINE_DB=waline

# Demo Mode
DEMO_MODE=false

# Code Runner
CODE_RUNNER_PATH=/app/codeRunner
PLUGIN_RUNNER_PATH=/app/pluginRunner

