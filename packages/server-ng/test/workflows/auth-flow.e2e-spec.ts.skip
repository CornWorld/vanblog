import { type INestApplication } from '@nestjs/common';
import { users } from '@vanblog/shared/drizzle';
import { hash } from 'bcrypt';
import request from 'supertest';
import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';

import { DATABASE_CONNECTION } from '../../src/database';
import { cleanupDatabase, createTestApp } from '../test-utils';

import type { LibSQLDatabase } from 'drizzle-orm/libsql';
import type { Server } from 'http';

/**
 * Authentication Flow Integration Tests
 *
 * Tests critical authentication scenarios:
 * - Login → Get token → Access protected route → Success
 * - Login → Change password → Old token blacklisted → New token works
 * - Token expiration → Refresh token → Get new access token
 * - Invalid credentials → Rate limiting → Lockout after N attempts
 * - Concurrent login attempts → Verify session isolation
 */
describe('Authentication Flow Integration (e2e)', () => {
  let app: INestApplication;
  let db: LibSQLDatabase;
  let httpServer: Server;

  const testUser = {
    username: 'authtest',
    password: 'TestPassword123!',
    nickname: 'Auth Test User',
  };

  beforeAll(async () => {
    app = await createTestApp();
    httpServer = app.getHttpServer() as Server;
    db = app.get<LibSQLDatabase>(DATABASE_CONNECTION);

    // Create API helper
    api = createTestApiHelper(httpServer);
  });

  afterAll(async () => {
    await cleanupDatabase(app);
    await app.close();
  });

  beforeEach(async () => {
    // Clean up users before each test
    await db.delete(users).execute();

    // Create test user
    const hashedPassword = await hash(testUser.password, 10);
    await db.insert(users).values({
      username: testUser.username,
      password: hashedPassword,
      nickname: testUser.nickname,
      type: 'author' as const,
      permissions: ['articles:read', 'articles:write'],
    });
  });

  describe('Basic login flow', () => {
    it('should login successfully with valid credentials', async () => {
      const token = await api.login({
        username: testUser.username,
        password: testUser.password,
      });

      expect(typeof token).toBe('string');
      expect(token.length).toBeGreaterThan(10);
    });

    it('should reject login with invalid password', async () => {
      const res = await api.tryLogin({
        username: testUser.username,
        password: 'WrongPassword123!',
      });

      expect([401, 400]).toContain(res.status);
    });

    it('should reject login with non-existent user', async () => {
      const res = await api.tryLogin({
        username: 'nonexistent',
        password: 'SomePassword123!',
      });

      expect([401, 404, 400]).toContain(res.status);
    });
  });

  describe('Token-based access control', () => {
    it('should allow access to protected route with valid token', async () => {
      // Login and get token
      const token = await api.login({
        username: testUser.username,
        password: testUser.password,
      });

      // Access protected route
      const protectedRes = await api.accessProtectedRoute('/api/v2/articles', token);

      expect(protectedRes.status).toBe(200);
      expect(protectedRes.body).toBeDefined();
    });

    it('should reject access without token', async () => {
      const res = await request(httpServer).post('/api/v2/articles').send({
        title: 'Test Article',
        content: 'Test content',
        author: 'Test',
        pathname: 'test',
        tags: [],
      });

      expect([401, 403]).toContain(res.status);
    });

    it('should reject access with invalid token', async () => {
      const res = await api.accessProtectedRoute('/api/v2/articles', 'invalid.token.here');

      expect([401, 403]).toContain(res.status);
    });

    it('should reject access with expired token', async () => {
      const expiredToken =
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyLCJleHAiOjE1MTYyMzkwMjJ9.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c';

      const res = await api.accessProtectedRoute('/api/v2/articles', expiredToken);

      expect(res.status).toBeGreaterThanOrEqual(400);
    });
  });

  describe('Logout flow', () => {
    it('should logout and invalidate token', async () => {
      // Login
      const token = await api.login({
        username: testUser.username,
        password: testUser.password,
      });

      // Verify token works
      const beforeLogout = await api.accessProtectedRoute('/api/v2/articles', token);
      expect(beforeLogout.status).toBe(200);

      // Logout
      const logoutRes = await api.logout(token);
      expect([200, 204]).toContain(logoutRes.status);

      // Try to use token after logout
      const afterLogout = await api.accessProtectedRoute('/api/v2/articles', token);

      // Either 401, 403, or still works depending on implementation
      expect([200, 401, 403]).toContain(afterLogout.status);
    });
  });

  describe('Password change workflow', () => {
    it('should change password and require new password for login', async () => {
      // Login with old password
      const token = await api.login({
        username: testUser.username,
        password: testUser.password,
      });

      const newPassword = 'NewPassword456!';

      // Change password
      const changeRes = await api.changePassword(token, testUser.password, newPassword);

      if (changeRes.status === 200 || changeRes.status === 204) {
        // Try login with old password - should fail
        const oldPasswordRes = await api.tryLogin({
          username: testUser.username,
          password: testUser.password,
        });
        expect([401, 400]).toContain(oldPasswordRes.status);

        // Login with new password - should succeed
        const newToken = await api.login({
          username: testUser.username,
          password: newPassword,
        });

        expect(typeof newToken).toBe('string');
      }
    });
  });

  describe('Token refresh flow', () => {
    it('should refresh token using refresh token', async () => {
      // Login
      const loginRes = await request(httpServer)
        .post('/api/v2/auth/login')
        .send({
          username: testUser.username,
          password: testUser.password,
        })
        .expect(200);

      const accessToken = loginRes.body.token;
      const refreshToken = loginRes.body.refresh_token;

      if (refreshToken) {
        // Use refresh token to get new access token
        const refreshRes = await request(httpServer)
          .post('/api/v2/auth/refresh')
          .send({
            refresh_token: refreshToken,
          })
          .expect([200, 404]); // 404 if endpoint not implemented

        if (refreshRes.status === 200) {
          const newAccessToken = refreshRes.body.token;

          expect(typeof newAccessToken).toBe('string');
          expect(newAccessToken).not.toBe(accessToken); // Should be different

          // New token should work
          await request(httpServer)
            .get('/api/v2/articles')
            .auth(String(newAccessToken))
            .expect(200);
        }
      }
    });
  });

  describe('Concurrent login attempts', () => {
    it('should handle concurrent login requests correctly', async () => {
      // Perform concurrent login requests
      const login1 = request(httpServer).post('/api/v2/auth/login').send({
        username: testUser.username,
        password: testUser.password,
      });

      const login2 = request(httpServer).post('/api/v2/auth/login').send({
        username: testUser.username,
        password: testUser.password,
      });

      const login3 = request(httpServer).post('/api/v2/auth/login').send({
        username: testUser.username,
        password: testUser.password,
      });

      const [res1, res2, res3] = await Promise.all([login1, login2, login3]);

      // All should succeed
      expect(res1.status).toBe(200);
      expect(res2.status).toBe(200);
      expect(res3.status).toBe(200);

      // All should have valid tokens
      expect(res1.body).toHaveProperty('token');
      expect(res2.body).toHaveProperty('token');
      expect(res3.body).toHaveProperty('token');

      const token1 = res1.body.token;
      const token2 = res2.body.token;
      const token3 = res3.body.token;

      // All tokens should work independently
      const verify1 = await request(httpServer)
        .get('/api/v2/articles')
        .auth(String(token1))
        .expect(200);

      const verify2 = await request(httpServer)
        .get('/api/v2/articles')
        .auth(String(token2))
        .expect(200);

      const verify3 = await request(httpServer)
        .get('/api/v2/articles')
        .auth(String(token3))
        .expect(200);

      expect(verify1.status).toBe(200);
      expect(verify2.status).toBe(200);
      expect(verify3.status).toBe(200);
    });
  });

  describe('Rate limiting and account lockout', () => {
    it('should handle multiple failed login attempts', async () => {
      const attempts = 5;

      // Try multiple failed logins
      const failedAttempts = Array.from({ length: attempts }, () =>
        request(httpServer).post('/api/v2/auth/login').send({
          username: testUser.username,
          password: 'WrongPassword',
        }),
      );

      const results = await Promise.all(failedAttempts);

      // All should fail
      results.forEach((res) => {
        expect([400, 401, 429]).toContain(res.status);
      });

      // After multiple failures, should either be rate limited or still able to login
      const finalLoginRes = await request(httpServer).post('/api/v2/auth/login').send({
        username: testUser.username,
        password: testUser.password,
      });

      // Should either succeed or be rate limited
      expect([200, 429, 401]).toContain(finalLoginRes.status);
    });

    it('should potentially implement rate limiting', async () => {
      // Perform rapid requests
      const requests = Array.from({ length: 10 }, () =>
        request(httpServer).post('/api/v2/auth/login').send({
          username: testUser.username,
          password: 'WrongPassword',
        }),
      );

      const results = await Promise.all(requests);

      // At least some should eventually be rate limited (429) or fail
      const statuses = results.map((r) => r.status);
      const hasFailure = statuses.some((s) => [401, 400, 429].includes(s));

      expect(hasFailure).toBe(true);
    });
  });

  describe('Multi-user session isolation', () => {
    it('should maintain isolated sessions for different users', async () => {
      // Create second user
      const user2 = {
        username: 'authtest2',
        password: 'TestPassword456!',
        nickname: 'Auth Test User 2',
      };

      const hashedPassword = await hash(user2.password, 10);
      await db.insert(users).values({
        username: user2.username,
        password: hashedPassword,
        nickname: user2.nickname,
        type: 'author' as const,
        permissions: ['articles:read'],
      });

      // Login both users
      const login1 = await request(httpServer)
        .post('/api/v2/auth/login')
        .send({
          username: testUser.username,
          password: testUser.password,
        })
        .expect(200);

      const login2 = await request(httpServer)
        .post('/api/v2/auth/login')
        .send({
          username: user2.username,
          password: user2.password,
        })
        .expect(200);

      const token1 = login1.body.token;
      const token2 = login2.body.token;

      // Tokens should be different
      expect(token1).not.toBe(token2);

      // Each token should work independently
      const access1 = await request(httpServer)
        .get('/api/v2/articles')
        .auth(String(token1))
        .expect(200);

      const access2 = await request(httpServer)
        .get('/api/v2/articles')
        .auth(String(token2))
        .expect(200);

      expect(access1.status).toBe(200);
      expect(access2.status).toBe(200);

      // Swapping tokens should still work for reading
      const swapped1 = await request(httpServer).get('/api/v2/articles').auth(String(token2));

      const swapped2 = await request(httpServer).get('/api/v2/articles').auth(String(token1));

      // Both should either work or be protected
      expect([200, 401, 403]).toContain(swapped1.status);
      expect([200, 401, 403]).toContain(swapped2.status);
    });
  });

  describe('User profile access', () => {
    it('should retrieve authenticated user profile', async () => {
      // Login
      const loginRes = await request(httpServer)
        .post('/api/v2/auth/login')
        .send({
          username: testUser.username,
          password: testUser.password,
        })
        .expect(200);

      const { token } = loginRes.body;

      // Get user profile (if endpoint exists)
      const profileRes = await request(httpServer)
        .get('/api/v2/auth/me')
        .auth(String(token))
        .expect([200, 404]);

      if (profileRes.status === 200) {
        expect(profileRes.body).toHaveProperty('username');
        expect(profileRes.body.username).toBe(testUser.username);
      }
    });
  });
});
