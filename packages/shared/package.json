{
  "name": "@vanblog/shared",
  "version": "0.0.1",
  "type": "module",
  "description": "Shared contracts, schemas, and utilities for VanBlog",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./type": {
      "types": "./dist/type/index.d.ts",
      "import": "./dist/type/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "import": "./dist/contracts/*.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.ts",
      "import": "./dist/drizzle/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@ts-rest/core": "3.53.0-rc.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@zod-codepen/vite-plugin": "^1.0.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0"
  }
}
