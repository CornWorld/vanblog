{
  "name": "vanblog",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter vanblog-app dev",
    "build": "pnpm --filter vanblog-app build",
    "build:sdk": "pnpm --filter sdk build",
    "build:all": "pnpm --filter sdk build && pnpm --filter vanblog-app build",
    "preview": "pnpm --filter vanblog-app preview"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0"
  }
}
